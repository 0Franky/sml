{
  "name": "itlmv1-harness",
  "version": "0.0.1",
  "private": true,
  "description": "ITLMv1 harness — wrapper three-tier SLM su pi (extensions) + vLLM serving",
  "type": "module",
  "scripts": {
    "tui": "pi",
    "tui:debug": "node --inspect=127.0.0.1:9229 node_modules/@earendil-works/pi-coding-agent/dist/cli.js",
    "inspect": "node --experimental-sqlite tools/harness-inspect.mjs",
    "attach": "node tools/harness-attach.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node run-tests.mjs",
    "test:unit": "node run-tests.mjs unit",
    "test:integration": "node run-tests.mjs integration",
    "test:e2e": "node -e \"console.log('e2e behavioral (API-gated): lancia a mano, es. node test/e2e/dogfood-test.mjs <model> — richiede harness/.env')\""
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "typebox": "^1.1.38",
    "typescript": "^5.6.0"
  }
}
